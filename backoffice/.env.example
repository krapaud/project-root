# For manual (non-Docker) runs, SQLite is simplest (no separate DB server):
DATABASE_URL=sqlite:///./backoffice.db
# Docker Compose overrides this to Postgres (see ../docker-compose.yml);
# the code's own default (if this var is unset) is also Postgres.
PRODUCT_API_BASE_URL=http://localhost:5001
SESSION_SECRET_KEY=change-me-to-a-random-value
SEED_ADMIN_PASSWORD=ChangeMe123!
